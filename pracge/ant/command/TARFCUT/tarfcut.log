  --> Reading the Command file.
 
 ! Command file for ORANIG model !
 
 check-on-read elements = warn; ! very often needed
 cpu=yes ; ! (Optional) Reports CPU times for various stages
 log file = yes;  ! Optional
 auxiliary files = ORANIG; ! needed by GEMSIM
 
 ! Solution method
 Method = EULER;
 Steps = 3 4 5;
 
 ! Data and summary file
 File BASEDATA = ..\..\model\basedata.har ;
 Updated File BASEDATA =<cmf>.upd;
 File SUMMARY  = <cmf>sum.har;
 
 ! Set investment behavior for each set of industries
 Xset EXOGINV  # aggregated-investment driven investment industries #
     (ElecGasWater, Construction, FinanceInsur, OwnerDwellng,
      PropBusSrvc, GovAdminDfnc, Education, HealthCommun);
 Xsubset EXOGINV is Subset of IND;
 Xset ENDOGINV # profit-driven investment industries # = IND - EXOGINV;
 
 ! Mechanical closure !
 ! Supply-side shock
 Exogenous x1cap x1lnd capslack a1cap a1lab_o a1lnd a1prim a1tot a2tot f1lab_io;
 ! Demand-side shock
 Exogenous w3lux invslack f5tot2 f5 fx6;
 ! Foreign shock
 Exogenous pf0cif f4p f4q f4p_ntrad f4q_ntrad;
 ! Tax shock
 Exogenous delPTXRATE f0tax_s f1tax_csi f2tax_csi f3tax_cs f5tax_cs t0imp f4tax_trad f4tax_ntrad f1oct;
 ! Investment behavior
 Exogenous x2tot;
 ! Household
 Exogenous q a3_s;
 ! Numeraire
 Exogenous phi;
 ! Exogenous variables for regional extension
 exogenous freg1 freg2 freg3 freg4 freg5 freg6;
 exogenous rsum1 rsum2 rsum3 rsum4 rsum5 rsum6;
 
 Rest Endogenous;
 
 ! Short-run closure !
 Swap realwage = f1lab_io;
 Swap x3tot = w3lux;
 Swap x2tot_i = invslack;
 Swap x5tot = f5tot2;
 Swap delx6 = fx6;
 Swap finv1(ENDOGINV) = x2tot(ENDOGINV); ! investment driven by profitability
 Swap finv2(EXOGINV) = x2tot(EXOGINV); ! investment follows aggregated investment
 
 ! Long-run closure !
 !Swap gret = x1cap;
 !Swap employ_i = f1lab_io;
 !Swap delB = w3lux ;
 !Swap delx6 = fx6;
 !Swap finv3(ENDOGINV) = x2tot(ENDOGINV) ; ! investment follows existing capital
 !Swap finv2(EXOGINV) = x2tot(EXOGINV); ! investment follows aggregated investment
 
 Verbal Description = Short-run effect of cutting tariff rate
 on clothing & footwear sector by 10%;
 
 Extrapolation Accuracy File = yes;
 
 shock t0imp("ClothingFtw") = -10; ! cut tariff rate on ClothingFtw by 10%
 
 ! end of command file !
 
